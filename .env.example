# =============================================================================
# APP-DEV TEMPLATE — Environment Variables
# Copy to .env.local and fill in your values
# =============================================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Supabase (OBRIGATÓRIO — backend + frontend) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Database (conexão direta, opcional) ---
DATABASE_URL="postgresql://user:password@localhost:5432/appdev?schema=public"

# --- Telegram (alertas diários) ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- WhatsApp via Evolution API (opcional) ---
EVOLUTION_API_URL=https://your-evolution-server.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=bullcast
WHATSAPP_NUMBERS=5511999999999

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Langfuse (LLM Observability) ---
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Phoenix Arize (ML Observability) ---
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_BASE_URL=https://app.phoenix.arize.com

# --- Pinecone (Vector DB) ---
PINECONE_API_KEY=pcsk_xxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=app-dev

# --- PostHog (Product Analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Firecrawl (Web Scraping MCP) ---
FIRECRAWL_API_KEY=fc-xxx

# --- Vercel ---
VERCEL_TOKEN=xxx
VERCEL_ORG_ID=xxx
VERCEL_PROJECT_ID=xxx

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=app-dev
